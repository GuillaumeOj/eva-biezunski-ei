# Brevo transactional email — used by the contact form (POST /api/contact).
# Copy to .env.local and fill in real values (never commit secrets).

# API key from your Brevo account (SMTP & API > API Keys). Required.
BREVO_API_KEY=

# Verified sender email/domain in Brevo (the "from" address). Required.
BREVO_SENDER_EMAIL=

# Recipient for contact-form notifications. Optional — defaults to the public
# contact email (eva@biezunski-avocat.fr) defined in src/lib/constants.ts.
BREVO_TO_EMAIL=
